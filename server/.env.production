# Database
DB_USER=studypilot
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_NAME=studypilot
DATABASE_URL=postgresql+asyncpg://studypilot:CHANGE_ME_TO_STRONG_PASSWORD@db:5432/studypilot

# Redis
REDIS_URL=redis://redis:6379/0

# JWT - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Share link JWT
SHARE_TOKEN_SECRET=CHANGE_ME_TO_ANOTHER_SECRET
SHARE_TOKEN_EXPIRE_DAYS=7

# Admin credentials
ADMIN_PHONE=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# LLM API Keys
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Application
UPLOAD_DIR=/app/uploads
MODEL_CONFIG_PATH=config/model_config.yaml
CORS_ORIGINS=["https://your-domain.com"]
DEBUG=false

# Deployment
API_WORKERS=2
LOG_LEVEL=info
HTTP_PORT=80
