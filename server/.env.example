# Database
DATABASE_URL=postgresql+asyncpg://studypilot:studypilot@localhost:5432/studypilot
DB_USER=studypilot
DB_PASSWORD=change-me-db-password
DB_NAME=studypilot

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
SHARE_TOKEN_SECRET=change-me-share-secret
SHARE_TOKEN_EXPIRE_DAYS=7

# Admin credentials (seeded on first run)
ADMIN_PHONE=admin
ADMIN_PASSWORD=changeme

# Storage
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Model provider keys
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Debug
DEBUG=false

# Runtime
API_WORKERS=2
LOG_LEVEL=info
HTTP_PORT=80
